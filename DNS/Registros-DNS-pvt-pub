# 1. ConfiguraciĂłn
$ResolverIP = "10.64.1.20"
$SubscriptionId = "Desarrollo"

Write-Host "--- Conectando a la suscripciĂłn: $SubscriptionId ---" -ForegroundColor Cyan
Set-AzContext -Subscription $SubscriptionId | Out-Null

$Inventario = @()

# 2 y 3. ExtracciĂłn Absoluta de Recursos y ExpansiĂłn de FQDNs
Write-Host "--- Descargando inventario global de la suscripciĂłn ---" -ForegroundColor Cyan
Write-Host "Escaneando TODOS los objetos para mapear sus FQDNs pĂşblicos..." -ForegroundColor Gray

# Traemos el 100% de los recursos de la suscripciĂłn de un solo golpe
$TodosLosRecursos = Get-AzResource -ErrorAction SilentlyContinue

foreach ($res in $TodosLosRecursos) {
    $name = $res.Name
    $type = $res.ResourceType

    # Mapeo masivo de tipos de recurso de Azure a sus FQDNs pĂşblicos oficiales
    switch ($type) {
        "Microsoft.Storage/storageAccounts" {
            $Suffixes = @("blob.core.windows.net", "file.core.windows.net", "queue.core.windows.net", "table.core.windows.net", "dfs.core.windows.net", "web.core.windows.net")
            foreach ($s in $Suffixes) { $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.$s"; Tipo="Storage ($s)" } }
        }
        "Microsoft.KeyVault/vaults" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.vault.azure.net"; Tipo="KeyVault" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.vaultcore.azure.net"; Tipo="KeyVault Core" }
        }
        "Microsoft.Sql/servers" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.database.windows.net"; Tipo="SQL Server" }
        }
        "Microsoft.Web/sites" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.azurewebsites.net"; Tipo="App Service / Function" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.scm.azurewebsites.net"; Tipo="App Service Kudu/SCM" }
        }
        "Microsoft.ContainerRegistry/registries" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.azurecr.io"; Tipo="Container Registry" }
        }
        "Microsoft.DataFactory/factories" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.datafactory.azure.net"; Tipo="Data Factory" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.portal.datafactory.azure.net"; Tipo="Data Factory Portal" }
        }
        "Microsoft.Databricks/workspaces" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.azuredatabricks.net"; Tipo="Databricks" }
        }
        "Microsoft.CognitiveServices/accounts" {
            # Cubre Azure OpenAI y servicios cognitivos tradicionales
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.openai.azure.com"; Tipo="Azure OpenAI" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.cognitiveservices.azure.com"; Tipo="Cognitive Service" }
        }
        "Microsoft.DocumentDB/databaseAccounts" {
            # Cubre TODAS las variantes de Cosmos DB que mencionabas
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.documents.azure.com"; Tipo="CosmosDB Core SQL" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.mongo.cosmos.azure.com"; Tipo="CosmosDB Mongo" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.cassandra.cosmos.azure.com"; Tipo="CosmosDB Cassandra" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.table.cosmos.azure.com"; Tipo="CosmosDB Table" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.gremlin.cosmos.azure.com"; Tipo="CosmosDB Gremlin" }
        }
        "Microsoft.MachineLearningServices/workspaces" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.api.azureml.ms"; Tipo="Machine Learning API" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.notebooks.azure.net"; Tipo="Machine Learning Notebooks" }
        }
        "Microsoft.Synapse/workspaces" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.dev.azuresynapse.net"; Tipo="Synapse Dev" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.sql.azuresynapse.net"; Tipo="Synapse SQL" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.web.azuresynapse.net"; Tipo="Synapse Web" }
        }
        "Microsoft.Cache/Redis" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.redis.cache.windows.net"; Tipo="Redis Cache" }
        }
        "Microsoft.ServiceBus/namespaces" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.servicebus.windows.net"; Tipo="Service Bus" }
        }
        "Microsoft.EventHub/namespaces" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.servicebus.windows.net"; Tipo="Event Hub Namespace" }
        }
        "Microsoft.Search/searchServices" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.search.windows.net"; Tipo="Azure Search" }
        }
        "Microsoft.Purview/accounts" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.purview.azure.com"; Tipo="Purview" }
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.scan.purview.azure.com"; Tipo="Purview Scan" }
        }
        "Microsoft.SignalRService/SignalR" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.service.signalr.net"; Tipo="SignalR" }
        }
        "Microsoft.Devices/IotHubs" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.azure-devices.net"; Tipo="IoT Hub" }
        }
        "Microsoft.Automation/automationAccounts" {
            $Inventario += [PSCustomObject]@{ Nombre=$name; FQDN="$name.azure-automation.net"; Tipo="Automation Account" }
        }
    }
}

Write-Host "Se generaron e identificaron $($Inventario.Count) FQDNs potenciales basados en tu infraestructura real." -ForegroundColor Yellow
Write-Host "--- Iniciando prueba DNS contra el Servidor $ResolverIP ---" -ForegroundColor Cyan

$Resultados = @()

# 4. Probar DNS usando TU Parser inteligente de nslookup (Se mantiene intacto porque te funcionĂł genial)
foreach ($Item in $Inventario) {
    Write-Host "Consultando: $($Item.FQDN)... " -NoNewline
    
    $Lookup = nslookup $($Item.FQDN) $ResolverIP 2>&1 | Out-String
    
    $IpResuelta = "N/A"
    $NombreRespuesta = "N/A"
    $IsAnswerSection = $false
    
    $Lines = $Lookup -split '\r?\n'

    foreach ($Line in $Lines) {
        if ($Line -match "(?i)(Non-authoritative answer|Respuesta no autoritativa)") {
            $IsAnswerSection = $true
        }
        elseif ($Line -match "^(?i)(Name|Nombre):\s+(.+)$") {
            $NombreRespuesta = $matches[2].Trim()
            $IsAnswerSection = $true
        }
        elseif ($Line -match "(?i)canonical name = (.+)\.?$") {
            $NombreRespuesta = $matches[1].Trim().TrimEnd('.')
            $IsAnswerSection = $true
        }
        elseif ($IsAnswerSection -and $Line -match "^(?i)Address:\s+([0-9\.]+)") {
            $IpResuelta = $matches[1].Trim()
        }
    }

    # EvaluaciĂłn del resultado final
    if ($IpResuelta -ne "N/A") {
        $EsPrivada = $IpResuelta -match "^(10\.|192\.168\.|172\.(1[6-9]|2[0-9]|3[0-1])\.)"
        $Estado = if ($EsPrivada) { "OK (PRIVADO)" } else { "ALERTA (PĂšBLICO)" }
        
        if ($EsPrivada) { Write-Host "Privado ($IpResuelta)" -ForegroundColor Green }
        else { Write-Host "PĂšBLICO ($IpResuelta)" -ForegroundColor Red }
    } else {
        $Estado = "NO RESOLVIĂ“ / TIMEOUT"
        Write-Host "No resolviĂł" -ForegroundColor DarkGray
    }

    $Resultados += [PSCustomObject]@{
        ServidorDNS    = $ResolverIP
        Recurso_Nombre = $Item.Nombre
        Tipo_Recurso   = $Item.Tipo
        FQDN           = $Item.FQDN
        Nombre_CNAME   = $NombreRespuesta
        IP_Resuelta    = $IpResuelta
        Estado         = $Estado
    }
}

# 5. Guardar el reporte en el Escritorio
if ($Resultados.Count -gt 0) {
    $RutaEscritorio = "$([Environment]::GetFolderPath('Desktop'))\Reporte_Auditoria_DNS_Total.csv"
    $Resultados | Export-Csv -Path $RutaEscritorio -NoTypeInformation -Encoding UTF8 -Delimiter ","
    
    Write-Host "`n====================================================" -ForegroundColor Cyan
    Write-Host "ÂˇREPORTE DE COBERTURA TOTAL GENERADO!" -ForegroundColor Green
    Write-Host "Ruta: $RutaEscritorio" -ForegroundColor Yellow
    Write-Host "====================================================`n"
}