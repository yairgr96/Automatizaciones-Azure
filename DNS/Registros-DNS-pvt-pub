# 1. Configuración
$ResolverIP = "10.64.1.20"
$SubscriptionId = "Desarrollo"

Write-Host "--- Conectando a la suscripción: $SubscriptionId ---" -ForegroundColor Cyan
Set-AzContext -Subscription $SubscriptionId | Out-Null

$Inventario = @()

# 2. Extracción de Recursos
Write-Host "--- Recopilando inventario PaaS de la suscripción ---" -ForegroundColor Cyan
Write-Host "Buscando Storage, SQL, KeyVault, CosmosDB, WebApps, ACR y Synapse..." -ForegroundColor Gray

<# $Storages   = Get-AzStorageAccount -ErrorAction SilentlyContinue
$Vaults     = Get-AzKeyVault -ErrorAction SilentlyContinue
$SqlServers = Get-AzSqlServer -ErrorAction SilentlyContinue
$WebApps    = Get-AzWebApp -ErrorAction SilentlyContinue
